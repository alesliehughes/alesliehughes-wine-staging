From 7d8757a2cfb12ae197203d880ccab5ac6eb71fa7 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 2 Jul 2026 16:01:42 +1000
Subject: [PATCH] fltmgr.sys: Add FltGetStreamContext stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 6 ++++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index daca3f92d58..39e3e94b327 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -80,7 +80,7 @@
 @ stub FltGetRequestorProcess
 @ stub FltGetRequestorProcessId
 @ stdcall FltGetRoutineAddress(str)
-@ stub FltGetStreamContext
+@ stdcall FltGetStreamContext(ptr ptr ptr)
 @ stub FltGetStreamHandleContext
 @ stub FltGetSwappedBufferMdlAddress
 @ stub FltGetTopInstance
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 6164dd9ff5d..044ca026a1b 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -160,3 +160,9 @@ void WINAPI FltReleaseContext(PFLT_CONTEXT context)
 {
     FIXME("%p\n", context);
 }
+
+NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE instance, PFILE_OBJECT  fileobject, PFLT_CONTEXT  *context)
+{
+    FIXME("%p, %p, %p\n", instance, fileobject, context);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index c47b3ad646b..31c26307084 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -657,6 +657,7 @@ NTSTATUS WINAPI FltAllocateContext(PFLT_FILTER, FLT_CONTEXT_TYPE, SIZE_T, POOL_T
 NTSTATUS WINAPI FltBuildDefaultSecurityDescriptor(PSECURITY_DESCRIPTOR *, ACCESS_MASK);
 void     WINAPI FltFreeSecurityDescriptor(PSECURITY_DESCRIPTOR);
 void*    WINAPI FltGetRoutineAddress(LPCSTR name);
+NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltRegisterFilter(PDRIVER_OBJECT, const FLT_REGISTRATION *, PFLT_FILTER *);
 VOID     WINAPI FltReleaseContext(PFLT_CONTEXT);
 NTSTATUS WINAPI FltStartFiltering(PFLT_FILTER);
-- 
2.53.0

