From e9dd43e55e6bf266beb8a4029afc4b68a9d6a673 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 2 Jul 2026 19:00:43 +1000
Subject: [PATCH] fltmgr.sys: Add FltGetFileNameInformation stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 6 ++++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 7867b56dd82..b1d09fcaf22 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -68,7 +68,7 @@
 @ stub FltGetDeviceObject
 @ stub FltGetDiskDeviceObject
 @ stub FltGetFileContext
-@ stub FltGetFileNameInformation
+@ stdcall FltGetFileNameInformation(ptr long ptr)
 @ stdcall FltGetFileNameInformationUnsafe(ptr ptr long ptr)
 @ stub FltGetFilterFromInstance
 @ stub FltGetFilterFromName
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index b1d734f5f5b..ea2045e5cfb 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -206,3 +206,9 @@ void WINAPI FltReleaseFileNameInformation(PFLT_FILE_NAME_INFORMATION information
 {
     FIXME("%p\n", information);
 }
+
+NTSTATUS WINAPI FltGetFileNameInformation(PFLT_CALLBACK_DATA callback, FLT_FILE_NAME_OPTIONS options, PFLT_FILE_NAME_INFORMATION *information)
+{
+    FIXME("%p, %lu, %p\n", callback, options, information);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index 189ad39db6a..ef461e8274f 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -692,6 +692,7 @@ typedef struct _FLT_FILE_NAME_INFORMATION
 NTSTATUS WINAPI FltAllocateContext(PFLT_FILTER, FLT_CONTEXT_TYPE, SIZE_T, POOL_TYPE, PFLT_CONTEXT*);
 NTSTATUS WINAPI FltBuildDefaultSecurityDescriptor(PSECURITY_DESCRIPTOR *, ACCESS_MASK);
 void     WINAPI FltFreeSecurityDescriptor(PSECURITY_DESCRIPTOR);
+NTSTATUS WINAPI FltGetFileNameInformation(PFLT_CALLBACK_DATA, FLT_FILE_NAME_OPTIONS, PFLT_FILE_NAME_INFORMATION *);
 NTSTATUS WINAPI FltGetFileNameInformationUnsafe(PFILE_OBJECT, PFLT_INSTANCE, FLT_FILE_NAME_OPTIONS, PFLT_FILE_NAME_INFORMATION *);
 void*    WINAPI FltGetRoutineAddress(LPCSTR name);
 NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
-- 
2.53.0

