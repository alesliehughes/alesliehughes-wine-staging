From b7f1b41d3d700fa3273b7fb434af4e203f5c3b86 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 2 Jul 2026 18:57:53 +1000
Subject: [PATCH] fltmgr.sys: Add FltReleaseFileNameInformation stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 5 +++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 1e60166022e..f81a6260f11 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -132,7 +132,7 @@
 @ stub FltReissueSynchronousIo
 @ stdcall FltReleaseContext(ptr)
 @ stub FltReleaseContexts
-@ stub FltReleaseFileNameInformation
+@ stdcall FltReleaseFileNameInformation(ptr)
 @ stdcall FltReleasePushLock(ptr)
 @ stub FltReleaseResource
 @ stub FltRequestOperationStatusCallback
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 6717a45434d..b1d734f5f5b 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -201,3 +201,8 @@ NTSTATUS WINAPI FltParseFileNameInformation(PFLT_FILE_NAME_INFORMATION informati
     FIXME("%p\n", information);
     return STATUS_NOT_SUPPORTED;
 }
+
+void WINAPI FltReleaseFileNameInformation(PFLT_FILE_NAME_INFORMATION information)
+{
+    FIXME("%p\n", information);
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index f3f7ee34537..189ad39db6a 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -701,6 +701,7 @@ NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE, PFILE_OBJECT, PLARGE_INTEGER, ULONG,
                             PULONG, PFLT_COMPLETED_ASYNC_IO_CALLBACK, PVOID);
 NTSTATUS WINAPI FltRegisterFilter(PDRIVER_OBJECT, const FLT_REGISTRATION *, PFLT_FILTER *);
 VOID     WINAPI FltReleaseContext(PFLT_CONTEXT);
+void     WINAPI FltReleaseFileNameInformation(PFLT_FILE_NAME_INFORMATION);
 NTSTATUS WINAPI FltSetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, FLT_SET_CONTEXT_OPERATION, PFLT_CONTEXT, PFLT_CONTEXT*);
 NTSTATUS WINAPI FltStartFiltering(PFLT_FILTER);
 void     WINAPI FltUnregisterFilter(PFLT_FILTER);
-- 
2.53.0

