From c5ad34b9fa54ce6a296b56db3accf8816d4e2209 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 2 Jul 2026 18:51:43 +1000
Subject: [PATCH] fltmgr.sys: Add FltParseFileNameInformation stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 6 ++++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 9d03c83a6d4..34a38e4ed90 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -113,7 +113,7 @@
 @ stub FltOplockFsctrl
 @ stub FltOplockIsFastIoPossible
 @ stub FltParseFileName
-@ stub FltParseFileNameInformation
+@ stdcall FltParseFileNameInformation(ptr)
 @ stub FltPerformAsynchronousIo
 @ stub FltPerformSynchronousIo
 @ stub FltProcessFileLock
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 034222c9e0b..6717a45434d 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -195,3 +195,9 @@ NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE instance, PFILE_OBJECT fileobject, PLA
     FIXME("%p, %p, %p, %lu, %p, 0x%lx, %p, %p, %p\n", instance, fileobject, offset, length, buffer, flags, read, callback, context);
     return STATUS_NOT_SUPPORTED;
 }
+
+NTSTATUS WINAPI FltParseFileNameInformation(PFLT_FILE_NAME_INFORMATION information)
+{
+    FIXME("%p\n", information);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index 083905dc553..f3f7ee34537 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -696,6 +696,7 @@ NTSTATUS WINAPI FltGetFileNameInformationUnsafe(PFILE_OBJECT, PFLT_INSTANCE, FLT
 void*    WINAPI FltGetRoutineAddress(LPCSTR name);
 NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltQueryInformationFile(PFLT_INSTANCE, PFILE_OBJECT, PVOID, ULONG, FILE_INFORMATION_CLASS, PULONG);
+NTSTATUS WINAPI FltParseFileNameInformation(PFLT_FILE_NAME_INFORMATION);
 NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE, PFILE_OBJECT, PLARGE_INTEGER, ULONG, PVOID, FLT_IO_OPERATION_FLAGS,
                             PULONG, PFLT_COMPLETED_ASYNC_IO_CALLBACK, PVOID);
 NTSTATUS WINAPI FltRegisterFilter(PDRIVER_OBJECT, const FLT_REGISTRATION *, PFLT_FILTER *);
-- 
2.53.0

