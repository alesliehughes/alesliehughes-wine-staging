From 859e9d253dc3e4d2dc0d04b39412798289d4db6b Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 2 Jul 2026 21:45:08 +1000
Subject: [PATCH] fltmgr.sys: Add FltCreateCommunicationPort stub

Wine-Bug: https://bugs.winehq.org/show_bug.cgi?id=56501
---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 9 +++++++++
 include/ddk/fltkernel.h         | 7 +++++++
 3 files changed, 17 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 883fadc693e..960c1e50188 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -31,7 +31,7 @@
 @ stub FltCompareInstanceAltitudes
 @ stub FltCompletePendedPostOperation
 @ stub FltCompletePendedPreOperation
-@ stub FltCreateCommunicationPort
+@ stdcall FltCreateCommunicationPort(ptr ptr ptr ptr ptr ptr ptr long)
 @ stub FltCreateFile
 @ stub FltCreateFileEx
 @ stub FltCreateSystemVolumeInformationFolder
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index ea2045e5cfb..27a04274930 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -212,3 +212,12 @@ NTSTATUS WINAPI FltGetFileNameInformation(PFLT_CALLBACK_DATA callback, FLT_FILE_
     FIXME("%p, %lu, %p\n", callback, options, information);
     return STATUS_NOT_SUPPORTED;
 }
+
+NTSTATUS WINAPI FltCreateCommunicationPort(PFLT_FILTER filter, PFLT_PORT *port, POBJECT_ATTRIBUTES attributes,
+        PVOID cookie, PFLT_CONNECT_NOTIFY  connect_callback, PFLT_DISCONNECT_NOTIFY disconnect_callback,
+        PFLT_MESSAGE_NOTIFY message_callback, LONG max_connections)
+{
+    FIXME("%p, %p, %p, %p, %p, %p, %p, %ld\n", filter, port, attributes, cookie, connect_callback, disconnect_callback,
+                        message_callback, max_connections);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index ef461e8274f..99da0278719 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -585,6 +585,8 @@ typedef struct _FLT_CALLBACK_DATA
     KPROCESSOR_MODE RequestorMode;
 } FLT_CALLBACK_DATA, *PFLT_CALLBACK_DATA;
 
+typedef struct _FLT_PORT *PFLT_PORT;
+
 typedef void*    (__WINE_ALLOC_SIZE(2) WINAPI *PFLT_CONTEXT_ALLOCATE_CALLBACK)(POOL_TYPE,SIZE_T,FLT_CONTEXT_TYPE);
 typedef void     (WINAPI *PFLT_CONTEXT_CLEANUP_CALLBACK)(PFLT_CONTEXT, FLT_CONTEXT_TYPE);
 typedef void     (WINAPI *PFLT_CONTEXT_FREE_CALLBACK)(void *, FLT_CONTEXT_TYPE);
@@ -610,6 +612,9 @@ typedef NTSTATUS (WINAPI *PFLT_SECTION_CONFLICT_NOTIFICATION_CALLBACK)(PFLT_INST
                 PFLT_CALLBACK_DATA);
 typedef NTSTATUS (WINAPI *PFLT_TRANSACTION_NOTIFICATION_CALLBACK)(PCFLT_RELATED_OBJECTS, PFLT_CONTEXT, ULONG);
 typedef void (WINAPI *PFLT_COMPLETED_ASYNC_IO_CALLBACK)(PFLT_CALLBACK_DATA,PFLT_CONTEXT Context);
+typedef NTSTATUS (WINAPI *PFLT_CONNECT_NOTIFY)(PFLT_PORT, PVOID, PVOID, ULONG, PVOID *);
+typedef NTSTATUS (WINAPI *PFLT_MESSAGE_NOTIFY)(PVOID,PVOID,ULONG,PVOID,ULONG,PULONG);
+typedef void (WINAPI *PFLT_DISCONNECT_NOTIFY)(PVOID);
 
 
 typedef struct _FLT_CONTEXT_REGISTRATION
@@ -691,6 +696,8 @@ typedef struct _FLT_FILE_NAME_INFORMATION
 
 NTSTATUS WINAPI FltAllocateContext(PFLT_FILTER, FLT_CONTEXT_TYPE, SIZE_T, POOL_TYPE, PFLT_CONTEXT*);
 NTSTATUS WINAPI FltBuildDefaultSecurityDescriptor(PSECURITY_DESCRIPTOR *, ACCESS_MASK);
+NTSTATUS WINAPI FltCreateCommunicationPort(PFLT_FILTER, PFLT_PORT*, POBJECT_ATTRIBUTES, PVOID, PFLT_CONNECT_NOTIFY,
+                                            PFLT_DISCONNECT_NOTIFY, PFLT_MESSAGE_NOTIFY, LONG);
 void     WINAPI FltFreeSecurityDescriptor(PSECURITY_DESCRIPTOR);
 NTSTATUS WINAPI FltGetFileNameInformation(PFLT_CALLBACK_DATA, FLT_FILE_NAME_OPTIONS, PFLT_FILE_NAME_INFORMATION *);
 NTSTATUS WINAPI FltGetFileNameInformationUnsafe(PFILE_OBJECT, PFLT_INSTANCE, FLT_FILE_NAME_OPTIONS, PFLT_FILE_NAME_INFORMATION *);
-- 
2.53.0

