From 00abd0b9edc55a52ba4447649409d5f1dee1db87 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 2 Jul 2026 18:49:43 +1000
Subject: [PATCH] fltmgr.sys: Add FltReadFile stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec |  2 +-
 dlls/fltmgr.sys/main.c          |  8 ++++++++
 include/ddk/fltkernel.h         | 11 +++++++++++
 3 files changed, 20 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index daefd06c61a..9d03c83a6d4 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -125,7 +125,7 @@
 @ stub FltQueryVolumeInformationFile
 @ stub FltQueueDeferredIoWorkItem
 @ stub FltQueueGenericWorkItem
-@ stub FltReadFile
+@ stdcall FltReadFile(ptr ptr ptr long ptr long ptr ptr ptr)
 @ stub FltReferenceContext
 @ stub FltReferenceFileNameInformation
 @ stdcall FltRegisterFilter(ptr ptr ptr)
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 9adb9899e82..034222c9e0b 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -187,3 +187,11 @@ NTSTATUS WINAPI FltGetFileNameInformationUnsafe(PFILE_OBJECT fileobject, PFLT_IN
     FIXME("%p, %p, %lu, %p\n", fileobject, instance, options, FileNameInformation);
     return STATUS_NOT_SUPPORTED;
 }
+
+NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE instance, PFILE_OBJECT fileobject, PLARGE_INTEGER offset,
+        ULONG length, PVOID buffer, FLT_IO_OPERATION_FLAGS flags, PULONG read,
+        PFLT_COMPLETED_ASYNC_IO_CALLBACK callback, PVOID context)
+{
+    FIXME("%p, %p, %p, %lu, %p, 0x%lx, %p, %p, %p\n", instance, fileobject, offset, length, buffer, flags, read, callback, context);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index 76e11b1d78c..083905dc553 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -609,6 +609,8 @@ typedef FLT_POSTOP_CALLBACK_STATUS (WINAPI *PFLT_POST_OPERATION_CALLBACK)(PFLT_C
 typedef NTSTATUS (WINAPI *PFLT_SECTION_CONFLICT_NOTIFICATION_CALLBACK)(PFLT_INSTANCE, PFLT_CONTEXT,
                 PFLT_CALLBACK_DATA);
 typedef NTSTATUS (WINAPI *PFLT_TRANSACTION_NOTIFICATION_CALLBACK)(PCFLT_RELATED_OBJECTS, PFLT_CONTEXT, ULONG);
+typedef void (WINAPI *PFLT_COMPLETED_ASYNC_IO_CALLBACK)(PFLT_CALLBACK_DATA,PFLT_CONTEXT Context);
+
 
 typedef struct _FLT_CONTEXT_REGISTRATION
 {
@@ -666,6 +668,13 @@ typedef USHORT FLT_FILE_NAME_PARSED_FLAGS;
 #define FLTFL_FILE_NAME_PARSED_STREAM          0x0004
 #define FLTFL_FILE_NAME_PARSED_PARENT_DIR      0x0008
 
+typedef ULONG FLT_IO_OPERATION_FLAGS;
+
+#define FLTFL_IO_OPERATION_NON_CACHED                0x00000001
+#define FLTFL_IO_OPERATION_PAGING                    0x00000002
+#define FLTFL_IO_OPERATION_DO_NOT_UPDATE_BYTE_OFFSET 0x00000004
+#define FLTFL_IO_OPERATION_SYNCHRONOUS_PAGING        0x00000008
+
 typedef struct _FLT_FILE_NAME_INFORMATION
 {
     USHORT Size;
@@ -687,6 +696,8 @@ NTSTATUS WINAPI FltGetFileNameInformationUnsafe(PFILE_OBJECT, PFLT_INSTANCE, FLT
 void*    WINAPI FltGetRoutineAddress(LPCSTR name);
 NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltQueryInformationFile(PFLT_INSTANCE, PFILE_OBJECT, PVOID, ULONG, FILE_INFORMATION_CLASS, PULONG);
+NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE, PFILE_OBJECT, PLARGE_INTEGER, ULONG, PVOID, FLT_IO_OPERATION_FLAGS,
+                            PULONG, PFLT_COMPLETED_ASYNC_IO_CALLBACK, PVOID);
 NTSTATUS WINAPI FltRegisterFilter(PDRIVER_OBJECT, const FLT_REGISTRATION *, PFLT_FILTER *);
 VOID     WINAPI FltReleaseContext(PFLT_CONTEXT);
 NTSTATUS WINAPI FltSetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, FLT_SET_CONTEXT_OPERATION, PFLT_CONTEXT, PFLT_CONTEXT*);
-- 
2.53.0

