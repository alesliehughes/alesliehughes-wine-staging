From a63896fb7c5743a486fee2b1e729141d3dee06ee Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 14 May 2026 10:58:57 +1000
Subject: [PATCH] urlmon: URLOpenStreamW Improve stub

Wine-Bug: https://bugs.winehq.org/show_bug.cgi?id=50535
---
 dlls/urlmon/umstream.c | 21 ++++++++++++++++++---
 1 file changed, 18 insertions(+), 3 deletions(-)

diff --git a/dlls/urlmon/umstream.c b/dlls/urlmon/umstream.c
index 466e7668906..4725ee31aad 100644
--- a/dlls/urlmon/umstream.c
+++ b/dlls/urlmon/umstream.c
@@ -362,9 +362,24 @@ HRESULT WINAPI URLOpenStreamW(LPUNKNOWN pCaller, LPCWSTR szURL, DWORD dwReserved
 /***********************************************************************
  *		URLOpenPullStreamW (URLMON.@)
  */
-HRESULT WINAPI URLOpenPullStreamW(IUnknown *caller, const WCHAR *url, DWORD reserved,
+HRESULT WINAPI URLOpenPullStreamW(IUnknown *caller, const WCHAR *szURL, DWORD reserved,
                                   IBindStatusCallback *callback)
 {
-    FIXME("%p %s %lu %p, stub!\n", caller, debugstr_w(url), reserved, callback);
-    return E_NOTIMPL;
+    HRESULT hr;
+    ProxyBindStatusCallback async_bsc;
+    IStream *pStream;
+
+    FIXME("%p %s %lu %p, stub!\n", caller, debugstr_w(szURL), reserved, callback);
+
+    if (!szURL)
+        return E_INVALIDARG;
+
+    async_bsc.IBindStatusCallback_iface.lpVtbl = &BlockingBindStatusCallbackVtbl;
+    async_bsc.pBSC = callback;
+
+    hr = URLStartDownload(szURL, &pStream, &async_bsc.IBindStatusCallback_iface);
+    if (SUCCEEDED(hr) && pStream)
+        IStream_Release(pStream);
+
+    return hr;
 }
-- 
