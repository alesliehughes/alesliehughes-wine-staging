+        [id(0x00000001)]
+        HRESULT Count([out, retval] long* Count);
+        [id(DISPID_NEWENUM)]
+        HRESULT _NewEnum([out, retval] IUnknown** _NewEnum);
+        [id(0x00000002)]
+        HRESULT GetDefaultRecognizer( [in, optional, defaultvalue(0)] long lcid, [out, retval] IInkRecognizer** DefaultRecognizer);
+        [id(DISPID_VALUE)]
+        HRESULT Item([in] long Index, [out, retval] IInkRecognizer** InkRecognizer);
+    };
+
     [
         progid("msinkaut.InkObject.1"),
         vi_progid("msinkaut.InkObject"),
@@ -1211,4 +1548,35 @@ cpp_quote("#endif /* _WINGDI_ */")
     {
         [default] interface IInkOverlay;
     }
+
