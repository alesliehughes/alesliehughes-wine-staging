+    {
+        properties:
+        methods:
+            [id(0x00000001)]
+            void RecognitionWithAlternates( [in] IInkRecognitionResult* RecognitionResult,
+                            [in] VARIANT CustomData, [in] InkRecognitionStatus RecognitionStatus);
+            [id(0x00000002)]
+            void Recognition( [in] BSTR RecognizedString, [in] VARIANT CustomData, [in] InkRecognitionStatus RecognitionStatus);
+    };
+
+    [
+        uuid(11a583f2-712d-4fea-abcf-ab4af38ea06b)
+    ]
