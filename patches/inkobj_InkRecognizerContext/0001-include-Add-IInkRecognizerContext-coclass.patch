+            [id(0x00000002)]
+            void CursorDown([in] IInkCursor* Cursor, [in] IInkStrokeDisp* Stroke);
+            [id(0x00000003)]
+            void NewPackets([in] IInkCursor* Cursor, [in] IInkStrokeDisp* Stroke, [in] long PacketCount,
+                            [in, out] VARIANT* PacketData);
+            [id(0x00000019)]
+            void DblClick([in, out] VARIANT_BOOL* Cancel);
+            [id(0x0000001f)]
+            void MouseMove([in] InkMouseButton Button, [in] InkShiftKeyModifierFlags Shift, [in] long pX,
+                            [in] long pY, [in, out] VARIANT_BOOL* Cancel);
+            [id(0x0000001b)]
+            void MouseDown([in] InkMouseButton Button, [in] InkShiftKeyModifierFlags Shift, [in] long pX, [in] long pY,
