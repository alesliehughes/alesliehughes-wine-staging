+#pragma makedep register
+
+import "unknwn.idl";
+import "objidl.idl";
+import "oaidl.idl";
+
+[
+    uuid(50ef4544-ac9f-4a8e-b21b-8a26180db13f),
+    threading(both)
+]
+coclass LocalThumbnailCache
+{
+    interface IThumbnailCache;
+}
+
+[
+    uuid(4db26476-6787-4046-b836-e8412a9e8a27),
