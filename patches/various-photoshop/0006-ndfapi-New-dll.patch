diff --git a/dlls/ndfapi/ndfapi_main.c b/dlls/ndfapi/ndfapi_main.c
new file mode 100755
index 00000000000..3e85c87aac0
--- /dev/null
+++ b/dlls/ndfapi/ndfapi_main.c
@@ -0,0 +1,69 @@
