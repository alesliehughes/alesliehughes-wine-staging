 WINE_CONFIG_MAKEFILE(dlls/traffic)
diff --git a/dlls/thumbcache/Makefile.in b/dlls/thumbcache/Makefile.in
new file mode 100644
index 00000000000..124c49f34b7
--- /dev/null
+++ b/dlls/thumbcache/Makefile.in
@@ -0,0 +1,5 @@
+MODULE    = thumbcache.dll
+
+SOURCES = \
+	thumbcache.c \
+	thumbcache_reg.idl
