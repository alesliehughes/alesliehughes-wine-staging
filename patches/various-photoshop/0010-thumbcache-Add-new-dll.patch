diff --git a/configure.ac b/configure.ac
index 9de736fcc3b..10d6dbbe95f 100644
--- a/configure.ac
+++ b/configure.ac
@@ -3221,6 +3221,7 @@ WINE_CONFIG_MAKEFILE(dlls/tdh/tests)
