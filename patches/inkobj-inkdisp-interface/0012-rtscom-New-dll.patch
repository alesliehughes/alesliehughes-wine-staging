diff --git a/dlls/rtscom/Makefile.in b/dlls/rtscom/Makefile.in
new file mode 100755
index 00000000000..e4ea85cc387
--- /dev/null
+++ b/dlls/rtscom/Makefile.in
@@ -0,0 +1,5 @@
+MODULE    = rtscom.dll
+
+SOURCES = \
+	rtscom_main.c \
+	rtscom_reg.idl
diff --git a/dlls/rtscom/rtscom.spec b/dlls/rtscom/rtscom.spec
new file mode 100755
index 00000000000..069be116271
--- /dev/null
+++ b/dlls/rtscom/rtscom.spec
@@ -0,0 +1,4 @@
+@ stdcall -private DllCanUnloadNow()
+@ stdcall -private DllGetClassObject(ptr ptr ptr)
+@ stdcall -private DllRegisterServer()
+@ stdcall -private DllUnregisterServer()
\ No newline at end of file
