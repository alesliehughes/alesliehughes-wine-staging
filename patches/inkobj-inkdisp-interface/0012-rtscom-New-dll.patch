 create mode 100755 dlls/rtscom/rtscom.spec
 create mode 100755 dlls/rtscom/rtscom_main.c
 create mode 100644 dlls/rtscom/rtscom_reg.idl

diff --git a/configure.ac b/configure.ac
index 3a184968931..516a7511281 100644
--- a/configure.ac
+++ b/configure.ac
@@ -3137,6 +3137,7 @@ WINE_CONFIG_MAKEFILE(dlls/rsabase)
