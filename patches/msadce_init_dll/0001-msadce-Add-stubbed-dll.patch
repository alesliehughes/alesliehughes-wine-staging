Subject: [PATCH] msadce: Add stubbed dll

---
 configure.ac              |  1 +
 dlls/msadce/Makefile.in   |  6 ++++++
 dlls/msadce/msadce.spec   |  4 ++++
 dlls/msadce/msadce_main.c | 35 +++++++++++++++++++++++++++++++++++
 loader/wine.inf.in        |  2 ++
 5 files changed, 48 insertions(+)
 create mode 100644 dlls/msadce/Makefile.in
 create mode 100644 dlls/msadce/msadce.spec
 create mode 100644 dlls/msadce/msadce_main.c

diff --git a/configure.ac b/configure.ac
index 31b56bac541..0e09b506241 100644
--- a/configure.ac
+++ b/configure.ac
@@ -2903,6 +2903,7 @@ WINE_CONFIG_MAKEFILE(dlls/msacm.dll16)
 WINE_CONFIG_MAKEFILE(dlls/msacm32.drv)
 WINE_CONFIG_MAKEFILE(dlls/msacm32)
 WINE_CONFIG_MAKEFILE(dlls/msacm32/tests)
+WINE_CONFIG_MAKEFILE(dlls/msadce)
 WINE_CONFIG_MAKEFILE(dlls/msado15)
 WINE_CONFIG_MAKEFILE(dlls/msado15/tests)
 WINE_CONFIG_MAKEFILE(dlls/msadp32.acm)
diff --git a/dlls/msadce/Makefile.in b/dlls/msadce/Makefile.in
new file mode 100644
index 00000000000..b30ed196f63
--- /dev/null
+++ b/dlls/msadce/Makefile.in
@@ -0,0 +1,6 @@
+MODULE    = msadce.dll
+IMPORTS   = oleaut32 ole32
+
+
+SOURCES = \
+	msadce_main.c
diff --git a/dlls/msadce/msadce.spec b/dlls/msadce/msadce.spec
new file mode 100644
index 00000000000..b16365d0c9f
--- /dev/null
+++ b/dlls/msadce/msadce.spec
@@ -0,0 +1,4 @@
+@ stdcall -private DllCanUnloadNow()
+@ stdcall -private DllGetClassObject(ptr ptr ptr)
+@ stdcall -private DllRegisterServer()
+@ stdcall -private DllUnregisterServer()
diff --git a/dlls/msadce/msadce_main.c b/dlls/msadce/msadce_main.c
new file mode 100644
index 00000000000..a56b6da5cac
--- /dev/null
+++ b/dlls/msadce/msadce_main.c
@@ -0,0 +1,35 @@
