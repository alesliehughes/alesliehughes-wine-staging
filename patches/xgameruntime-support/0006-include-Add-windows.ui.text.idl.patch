Subject: [PATCH 06/14] include: Add windows.ui.text.idl

---
 include/Makefile.in         |  1 +
 include/windows.ui.text.idl | 64 +++++++++++++++++++++++++++++++++++++
 2 files changed, 65 insertions(+)
 create mode 100644 include/windows.ui.text.idl

diff --git a/include/Makefile.in b/include/Makefile.in
index c0025b969f8..848864c599a 100644
--- a/include/Makefile.in
+++ b/include/Makefile.in
@@ -969,6 +969,7 @@ SOURCES = \
 	windows.ui.idl \
 	windows.ui.input.idl \
 	windows.ui.notifications.idl \
+	windows.ui.text.idl \
 	windows.ui.viewmanagement.core.idl \
 	windows.ui.viewmanagement.idl \
 	windows.ui.windowmanagement.idl \
diff --git a/include/windows.ui.text.idl b/include/windows.ui.text.idl
new file mode 100644
index 00000000000..28d2ecf144e
--- /dev/null
+++ b/include/windows.ui.text.idl
@@ -0,0 +1,64 @@
