+}
+
+static IDataTransferManagerInteropVtbl data_transfer_manager_interop_vtbl =
+{
+    data_transfer_manager_interop_QueryInterface,
+    data_transfer_manager_interop_AddRef,
+    data_transfer_manager_interop_Release,
