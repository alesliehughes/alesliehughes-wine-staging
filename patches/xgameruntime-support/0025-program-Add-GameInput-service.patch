 AddService=RpcSs,0,RpcSsService
@@ -177,6 +179,7 @@ AddService=nsiproxy,0x800,NsiProxyService
 [DefaultInstall.ntamd64.Services]
 AddService=BITS,0,BITSService
 AddService=EventLog,0x800,EventLogService
+AddService=GameInput,0,GameInputService
 AddService=HTTP,0,HTTPService
 AddService=MSIServer,0,MSIService
 AddService=RpcSs,0,RpcSsService
@@ -197,6 +200,7 @@ AddService=nsiproxy,0x800,NsiProxyService
 [DefaultInstall.ntarm64.Services]
 AddService=BITS,0,BITSService
 AddService=EventLog,0x800,EventLogService
+AddService=GameInput,0,GameInputService
 AddService=HTTP,0,HTTPService
 AddService=MSIServer,0,MSIService
 AddService=RpcSs,0,RpcSsService
@@ -1018,6 +1022,7 @@ HKLM,SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\x86,"Version",2,"14.42.344
 11,,wminet_utils.dll,-
 ; some programs are 64-bit only
 11,,conhost.exe,-
+11,,gameinputsvc.exe,-
 11,,plugplay.exe,-
 11,,rpcss.exe,-
 11,,services.exe,-
@@ -1245,6 +1250,14 @@ StartType=3
 ErrorControl=1
 LoadOrderGroup="SpoolerGroup"
 
+[GameInputService]
+Description="Gaming input for Keyboard/Mouse/etc"
+DisplayName="Gaming Input"
+ServiceBinary="%11%\gameinputsvc.exe"
+ServiceType=32
+StartType=3
+ErrorControl=1
+
 [SpoolerServiceKeys]
 HKLM,"System\CurrentControlSet\Services\Spooler\Performance","Library",,"winspool.drv"
 HKLM,"System\CurrentControlSet\Services\Spooler\Performance","Open",,"PerfOpen"
diff --git a/programs/gameinputsvc/Makefile.in b/programs/gameinputsvc/Makefile.in
new file mode 100644
index 00000000000..9993cf756b3
--- /dev/null
+++ b/programs/gameinputsvc/Makefile.in
@@ -0,0 +1,7 @@
+MODULE    = gameinputsvc.exe
+IMPORTS   = advapi32
+
+EXTRADLLFLAGS = -mconsole -municode
+
+SOURCES = \
+	main.c
diff --git a/programs/gameinputsvc/main.c b/programs/gameinputsvc/main.c
new file mode 100644
index 00000000000..ed30d1d1424
--- /dev/null
+++ b/programs/gameinputsvc/main.c
@@ -0,0 +1,100 @@
