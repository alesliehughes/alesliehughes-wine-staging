From 7b261d56b1d2b174e4cbae04a25538df189df740 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 9 Jul 2026 16:06:44 +1000
Subject: [PATCH] fltmgr.sys: Add FltSendMessage stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 7 +++++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 9 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 98db93973f4..1515f712c2a 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -138,7 +138,7 @@
 @ stub FltRequestOperationStatusCallback
 @ stub FltRetainSwappedBufferMdlAddress
 @ stub FltReuseCallbackData
-@ stub FltSendMessage
+@ stdcall FltSendMessage(ptr ptr ptr long ptr ptr ptr)
 @ stub FltSetCallbackDataDirty
 @ stub FltSetCancelCompletion
 @ stub FltSetEaFile
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 229458862e7..1f01515707f 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -291,3 +291,10 @@ void WINAPI FltObjectDereference (void* object)
 {
     FIXME("%p\n", object);
 }
+
+NTSTATUS WINAPI FltSendMessage (PFLT_FILTER filter, PFLT_PORT *port, PVOID buffer, ULONG buf_len,
+    PVOID reply, PULONG reply_len, PLARGE_INTEGER timeout)
+{
+    FIXME("%p, %p, %p, %lu, %p %p %p\n", filter, port, buffer, buf_len, reply, reply_len, timeout);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index 93b9ae4c7a0..a491b30bfbc 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -791,6 +791,7 @@ NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE, PFILE_OBJECT, PLARGE_INTEGER, ULONG,
 NTSTATUS WINAPI FltRegisterFilter(PDRIVER_OBJECT, const FLT_REGISTRATION *, PFLT_FILTER *);
 VOID     WINAPI FltReleaseContext(PFLT_CONTEXT);
 void     WINAPI FltReleaseFileNameInformation(PFLT_FILE_NAME_INFORMATION);
+NTSTATUS WINAPI FltSendMessage (PFLT_FILTER, PFLT_PORT *, void*, ULONG, void*, PULONG, PLARGE_INTEGER);
 NTSTATUS WINAPI FltSetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, FLT_SET_CONTEXT_OPERATION, PFLT_CONTEXT, PFLT_CONTEXT*);
 NTSTATUS WINAPI FltSetStreamHandleContext (PFLT_INSTANCE, PFILE_OBJECT, FLT_SET_CONTEXT_OPERATION,
                                             PFLT_CONTEXT, PFLT_CONTEXT *);
-- 
2.53.0

