From 44da7be30711428ee9196bdef97766835d29a5ba Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 9 Jul 2026 14:38:12 +1000
Subject: [PATCH] fltmgr.sys: Add FltFreePoolAlignedWithTag stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 5 +++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index f6e876f2f28..468bac424dd 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -59,7 +59,7 @@
 @ stub FltFreeDeferredIoWorkItem
 @ stub FltFreeFileLock
 @ stub FltFreeGenericWorkItem
-@ stub FltFreePoolAlignedWithTag
+@ stdcall FltFreePoolAlignedWithTag(ptr ptr long)
 @ stdcall FltFreeSecurityDescriptor(ptr)
 @ stub FltFsControlFile
 @ stub FltGetBottomInstance
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index c9c22116cc1..dd2fddac832 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -259,3 +259,8 @@ void* WINAPI FltAllocatePoolAlignedWithTag(PFLT_INSTANCE instance, POOL_TYPE typ
     FIXME("%p, %u, %Iu, %lu\n", instance, type, bytes, tag);
     return NULL;
 }
+
+void WINAPI FltFreePoolAlignedWithTag(PFLT_INSTANCE instance, void* buffer, ULONG tag)
+{
+    FIXME("%p, %p, %lu\n", instance, buffer, tag);
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index a48f081b3bf..e6b38ad53c3 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -766,6 +766,7 @@ void*    WINAPI FltGetRoutineAddress(LPCSTR name);
 NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltGetStreamHandleContext (PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltQueryInformationFile(PFLT_INSTANCE, PFILE_OBJECT, PVOID, ULONG, FILE_INFORMATION_CLASS, PULONG);
+void     WINAPI FltFreePoolAlignedWithTag(PFLT_INSTANCE, void*, ULONG);
 NTSTATUS WINAPI FltParseFileNameInformation(PFLT_FILE_NAME_INFORMATION);
 NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE, PFILE_OBJECT, PLARGE_INTEGER, ULONG, PVOID, FLT_IO_OPERATION_FLAGS,
                             PULONG, PFLT_COMPLETED_ASYNC_IO_CALLBACK, PVOID);
-- 
2.53.0

