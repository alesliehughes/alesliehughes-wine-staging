-    FLT_FSTYPE_OPENAFS
-} FLT_FILESYSTEM_TYPE, *PFLT_FILESYSTEM_TYPE;
-
 typedef struct _FLT_NAME_CONTROL
 {
     UNICODE_STRING Name;
diff --git a/include/fltuser.h b/include/fltuser.h
index 43c572d2722..47cbf0bbf1a 100644
