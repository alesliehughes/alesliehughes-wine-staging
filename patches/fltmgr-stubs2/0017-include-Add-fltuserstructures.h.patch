+    ULONGLONG MessageId;
+} FILTER_MESSAGE_HEADER, *PFILTER_MESSAGE_HEADER;
+
+typedef struct _FILTER_REPLY_HEADER
+{
+    NTSTATUS  Status;
+    ULONGLONG MessageId;
+} FILTER_REPLY_HEADER, *PFILTER_REPLY_HEADER;
