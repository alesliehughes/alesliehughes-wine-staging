From 6697fd70f3a69fa426631c7762a724b9bc42a3e6 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 9 Jul 2026 15:56:47 +1000
Subject: [PATCH] fltmgr.sys: Add FltGetVolumeProperties stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 6 ++++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 165171816f5..a8d7168b4a4 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -94,7 +94,7 @@
 @ stub FltGetVolumeGuidName
 @ stub FltGetVolumeInstanceFromName
 @ stub FltGetVolumeName
-@ stub FltGetVolumeProperties
+@ stdcall FltGetVolumeProperties(ptr ptr long ptr)
 @ stub FltInitializeFileLock
 @ stub FltInitializeOplock
 @ stdcall FltInitializePushLock(ptr)
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 42af6870691..97c78af3ed8 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -275,3 +275,9 @@ NTSTATUS WINAPI FltGetVolumeFromInstance (PFLT_INSTANCE instance, PFLT_VOLUME *v
     FIXME("%p, %p\n", instance, volume);
     return STATUS_NOT_SUPPORTED;
 }
+
+NTSTATUS WINAPI FltGetVolumeProperties (PFLT_VOLUME volume, PFLT_VOLUME_PROPERTIES properties, ULONG length, PULONG ret)
+{
+    FIXME("%p, %p, %lu, %p\n", volume, properties, length, ret);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index 8bee5c638f8..b02b4684f4c 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -767,6 +767,7 @@ void*    WINAPI FltGetRoutineAddress(LPCSTR name);
 NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltGetStreamHandleContext (PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltGetVolumeFromInstance (PFLT_INSTANCE, PFLT_VOLUME *);
+NTSTATUS WINAPI FltGetVolumeProperties (PFLT_VOLUME, PFLT_VOLUME_PROPERTIES, ULONG, PULONG);
 NTSTATUS WINAPI FltQueryInformationFile(PFLT_INSTANCE, PFILE_OBJECT, PVOID, ULONG, FILE_INFORMATION_CLASS, PULONG);
 void     WINAPI FltFreePoolAlignedWithTag(PFLT_INSTANCE, void*, ULONG);
 NTSTATUS WINAPI FltParseFileNameInformation(PFLT_FILE_NAME_INFORMATION);
-- 
2.53.0

