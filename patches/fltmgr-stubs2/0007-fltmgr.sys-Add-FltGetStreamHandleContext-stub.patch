From e0c39db64714fad8d82f4a8251d60c1be166a788 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 9 Jul 2026 12:43:21 +1000
Subject: [PATCH] fltmgr.sys: Add FltGetStreamHandleContext stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 6 ++++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index b0d3f140a98..37dd66ccfdb 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -81,7 +81,7 @@
 @ stub FltGetRequestorProcessId
 @ stdcall FltGetRoutineAddress(str)
 @ stdcall FltGetStreamContext(ptr ptr ptr)
-@ stub FltGetStreamHandleContext
+@ stdcall FltGetStreamHandleContext(ptr ptr ptr)
 @ stub FltGetSwappedBufferMdlAddress
 @ stub FltGetTopInstance
 @ stub FltGetTunneledName
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 705410c8057..146a0401aff 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -247,3 +247,9 @@ NTSTATUS WINAPI FltSetStreamHandleContext (PFLT_INSTANCE instance, PFILE_OBJECT
     FIXME("%p, %p, %d, %p %p\n", instance, fileobject, operation, new_context, old_context);
     return STATUS_NOT_SUPPORTED;
 }
+
+NTSTATUS WINAPI FltGetStreamHandleContext (PFLT_INSTANCE instance, PFILE_OBJECT fileobject, PFLT_CONTEXT *Context)
+{
+    FIXME("%p, %p, %p\n", instance, fileobject, Context);
+    return STATUS_NOT_SUPPORTED;
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index 03b6aa99bd1..c9a3abf36b8 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -777,6 +777,7 @@ NTSTATUS WINAPI FltGetFileNameInformation(PFLT_CALLBACK_DATA, FLT_FILE_NAME_OPTI
 NTSTATUS WINAPI FltGetFileNameInformationUnsafe(PFILE_OBJECT, PFLT_INSTANCE, FLT_FILE_NAME_OPTIONS, PFLT_FILE_NAME_INFORMATION *);
 void*    WINAPI FltGetRoutineAddress(LPCSTR name);
 NTSTATUS WINAPI FltGetStreamContext(PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
+NTSTATUS WINAPI FltGetStreamHandleContext (PFLT_INSTANCE, PFILE_OBJECT, PFLT_CONTEXT *);
 NTSTATUS WINAPI FltQueryInformationFile(PFLT_INSTANCE, PFILE_OBJECT, PVOID, ULONG, FILE_INFORMATION_CLASS, PULONG);
 NTSTATUS WINAPI FltParseFileNameInformation(PFLT_FILE_NAME_INFORMATION);
 NTSTATUS WINAPI FltReadFile(PFLT_INSTANCE, PFILE_OBJECT, PLARGE_INTEGER, ULONG, PVOID, FLT_IO_OPERATION_FLAGS,
-- 
2.53.0

