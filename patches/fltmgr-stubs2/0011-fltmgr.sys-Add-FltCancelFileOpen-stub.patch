From 2e03b32dd2c23554e97a7aa68df3df87b94676d9 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Thu, 9 Jul 2026 15:04:52 +1000
Subject: [PATCH] fltmgr.sys: Add FltCancelFileOpen stub

---
 dlls/fltmgr.sys/fltmgr.sys.spec | 2 +-
 dlls/fltmgr.sys/main.c          | 5 +++++
 include/ddk/fltkernel.h         | 1 +
 3 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/dlls/fltmgr.sys/fltmgr.sys.spec b/dlls/fltmgr.sys/fltmgr.sys.spec
index 468bac424dd..5b3b131d5f9 100644
--- a/dlls/fltmgr.sys/fltmgr.sys.spec
+++ b/dlls/fltmgr.sys/fltmgr.sys.spec
@@ -11,7 +11,7 @@
 @ stub FltAttachVolume
 @ stub FltAttachVolumeAtAltitude
 @ stdcall FltBuildDefaultSecurityDescriptor(ptr long)
-@ stub FltCancelFileOpen
+@ stdcall FltCancelFileOpen(ptr ptr)
 @ stub FltCancelIo
 @ stub FltCbdqDisable
 @ stub FltCbdqEnable
diff --git a/dlls/fltmgr.sys/main.c b/dlls/fltmgr.sys/main.c
index 5cbbc253102..7f3695aed1a 100644
--- a/dlls/fltmgr.sys/main.c
+++ b/dlls/fltmgr.sys/main.c
@@ -269,3 +269,8 @@ void WINAPI FltFreePoolAlignedWithTag(PFLT_INSTANCE instance, void* buffer, ULON
     FIXME("%p, %p, %lu semi-stub\n", instance, buffer, tag);
     ExFreePoolWithTag(buffer, tag);
 }
+
+void WINAPI FltCancelFileOpen (PFLT_INSTANCE instance, PFILE_OBJECT fileobject)
+{
+    FIXME("%p, %p\n", instance, fileobject);
+}
diff --git a/include/ddk/fltkernel.h b/include/ddk/fltkernel.h
index a74d6178b0c..d24bd0a16e3 100644
--- a/include/ddk/fltkernel.h
+++ b/include/ddk/fltkernel.h
@@ -768,6 +768,7 @@ typedef struct _FLT_VOLUME_PROPERTIES
 NTSTATUS WINAPI FltAllocateContext(PFLT_FILTER, FLT_CONTEXT_TYPE, SIZE_T, POOL_TYPE, PFLT_CONTEXT*);
 void*    WINAPI FltAllocatePoolAlignedWithTag(PFLT_INSTANCE, POOL_TYPE, SIZE_T, ULONG);
 NTSTATUS WINAPI FltBuildDefaultSecurityDescriptor(PSECURITY_DESCRIPTOR *, ACCESS_MASK);
+void     WINAPI FltCancelFileOpen (PFLT_INSTANCE, PFILE_OBJECT);
 void     WINAPI FltCloseClientPort (PFLT_FILTER, PFLT_PORT *);
 void     WINAPI FltCloseCommunicationPort (PFLT_PORT);
 NTSTATUS WINAPI FltCreateCommunicationPort(PFLT_FILTER, PFLT_PORT*, POBJECT_ATTRIBUTES, PVOID, PFLT_CONNECT_NOTIFY,
-- 
2.53.0

