From 1ae4d024713c16995dda87e1c92649bb98861b30 Mon Sep 17 00:00:00 2001
From: Alistair Leslie-Hughes <leslie_alistair@hotmail.com>
Date: Sat, 11 Jul 2026 21:56:03 +1000
Subject: [PATCH] ntoskrnl.exe: Add IoOpenDriverRegistryKey stub

---
 dlls/ntoskrnl.exe/ntoskrnl.exe.spec | 1 +
 dlls/ntoskrnl.exe/pnp.c             | 8 ++++++++
 include/ddk/wdm.h                   | 1 +
 3 files changed, 10 insertions(+)

diff --git a/dlls/ntoskrnl.exe/ntoskrnl.exe.spec b/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
index 2829e97ddf9..ab8c82d94a3 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
+++ b/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
@@ -439,6 +439,7 @@
 @ stub IoMakeAssociatedIrp
 @ stub IoOpenDeviceInterfaceRegistryKey
 @ stdcall IoOpenDeviceRegistryKey(ptr long long ptr)
+@ stdcall IoOpenDriverRegistryKey(ptr long long long ptr)
 @ stub IoPageRead
 @ stub IoPnPDeliverServicePowerNotification
 @ stdcall IoQueryDeviceDescription(ptr ptr ptr ptr ptr ptr ptr ptr)
diff --git a/dlls/ntoskrnl.exe/pnp.c b/dlls/ntoskrnl.exe/pnp.c
index 11a578a7545..b903f5b66b2 100644
--- a/dlls/ntoskrnl.exe/pnp.c
+++ b/dlls/ntoskrnl.exe/pnp.c
@@ -1637,3 +1637,11 @@ void CDECL wine_enumerate_root_devices( const WCHAR *driver_name )
 
     SetupDiDestroyDeviceInfoList(set);
 }
+
+NTSTATUS WINAPI IoOpenDriverRegistryKey(PDRIVER_OBJECT driverobject, DRIVER_REGKEY_TYPE type,  ACCESS_MASK mask,
+        ULONG flags, PHANDLE key)
+{
+    FIXME("%p %d, %ld, 0x%lx, %p\n", driverobject, type, mask, flags, key);
+
+    return STATUS_NOT_IMPLEMENTED;
+}
diff --git a/include/ddk/wdm.h b/include/ddk/wdm.h
index 09784f150b2..5b2e7f64741 100644
--- a/include/ddk/wdm.h
+++ b/include/ddk/wdm.h
@@ -1822,6 +1822,7 @@ void      WINAPI IoInvalidateDeviceRelations(PDEVICE_OBJECT,DEVICE_RELATION_TYPE
 BOOLEAN   WINAPI IoIs32bitProcess(IRP*);
 #endif
 NTSTATUS  WINAPI IoOpenDeviceRegistryKey(DEVICE_OBJECT*,ULONG,ACCESS_MASK,HANDLE*);
+NTSTATUS  WINAPI IoOpenDriverRegistryKey(PDRIVER_OBJECT, DRIVER_REGKEY_TYPE, ACCESS_MASK, ULONG, PHANDLE);
 void      WINAPI IoQueueWorkItem(PIO_WORKITEM,PIO_WORKITEM_ROUTINE,WORK_QUEUE_TYPE,void*);
 NTSTATUS  WINAPI IoRegisterDeviceInterface(PDEVICE_OBJECT,const GUID*,PUNICODE_STRING,PUNICODE_STRING);
 void      WINAPI IoReleaseCancelSpinLock(KIRQL);
-- 
2.53.0

